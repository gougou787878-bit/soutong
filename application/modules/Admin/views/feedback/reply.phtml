        <div class="layui-form-item">
            <label class="layui-form-label">回复对象：</label>
            <div class="layui-input-block">
                <input type="text" style="width:500px;" name="touid" id="uid"  value="<?= $data['uid']; ?>" readonly >
                <input type="hidden" id="fid" name="fid" value="<?= $data['id']; ?>">
            </div>

