<script>
    (function () {
        layui.use(['form', 'jquery'], function () {
            var form = layui.form, $ = layui.jquery;
            var VIP_PRODUCTS_BY_LEVEL = <?php echo isset($vip_products_by_level_json) ? $vip_products_by_level_json : '{}'; ?>;
            function decodeExtra(row) {
                var ex = row && row.extra;
                if (!ex) return {};
                if (typeof ex === 'object') return ex;
                if (typeof ex === 'string') {
                    try { return JSON.parse(ex); } catch (e) { return {}; }
                }
                return {};
            }
            function flattenVipProducts() {
                var out = [];
                for (var level in VIP_PRODUCTS_BY_LEVEL) {
                    if (!Object.prototype.hasOwnProperty.call(VIP_PRODUCTS_BY_LEVEL, level)) continue;
                    var map = VIP_PRODUCTS_BY_LEVEL[level] || {};
                    for (var id in map) {
                        if (!Object.prototype.hasOwnProperty.call(map, id)) continue;
                        out.push({id: String(id), name: map[id], level: String(level)});
                    }
                }
                return out;
            }
            function refillVipRandomProducts(selectedIds) {
                selectedIds = selectedIds || [];
                var set = {};
                for (var i = 0; i < selectedIds.length; i++) set[String(selectedIds[i])] = true;
                var $sel = $('#mlp-vip-random-products');
                $sel.empty();
                var all = flattenVipProducts();
                all.sort(function (a, b) { return (a.level + ':' + a.id).localeCompare(b.level + ':' + b.id); });
                for (var j = 0; j < all.length; j++) {
                    var it = all[j];
                    var opt = document.createElement('option');
                    opt.value = it.id;
                    opt.text = (it.level ? ('[' + it.level + '] ') : '') + it.name + ' #' + it.id;
                    if (set[it.id]) opt.selected = true;
                    $sel.append(opt);
                }
            }
            function togglePrizeSections(prizeType) {
                var isCoins = prizeType === 'coins';
                var isVip = prizeType === 'vip';
                $('#mlp-coins-mode-wrap,#mlp-coins-fixed-wrap,#mlp-coins-random-wrap').toggle(isCoins);
                $('#mlp-vip-mode-wrap,#mlp-vip-fixed-wrap,#mlp-vip-random-wrap').toggle(isVip);
            }
            function syncModeVisibility() {
                var ct = $('select[name="prize_type"]').val() || '';
                togglePrizeSections(ct);
                var cm = $('input[name="coins_mode"]:checked').val() || 'fixed';
                $('#mlp-coins-fixed-wrap').toggle(ct === 'coins' && cm === 'fixed');
                $('#mlp-coins-random-wrap').toggle(ct === 'coins' && cm === 'random');
                var vm = $('input[name="vip_mode"]:checked').val() || 'fixed';
                $('#mlp-vip-fixed-wrap').toggle(ct === 'vip' && vm === 'fixed');
                $('#mlp-vip-random-wrap').toggle(ct === 'vip' && vm === 'random');
            }
            function refillVipProducts(level, selectedId, row) {
                var $p = $('#mlp-vip-product-id');
                $p.empty().append($('<option/>').val('').text('请选择VIP产品'));
                if (level && VIP_PRODUCTS_BY_LEVEL[level]) {
                    var map = VIP_PRODUCTS_BY_LEVEL[level];
                    for (var id in map) {
                        if (!Object.prototype.hasOwnProperty.call(map, id)) {
                            continue;
                        }
                        $p.append($('<option/>').val(id).text(map[id]));
                    }
                } else {
                    var all = flattenVipProducts();
                    all.sort(function (a, b) { return (a.level + ':' + a.id).localeCompare(b.level + ':' + b.id); });
                    for (var k = 0; k < all.length; k++) {
                        var it = all[k];
                        $p.append($('<option/>').val(it.id).text(it.name));
                    }
                }
                if (selectedId) {
                    var sid = String(selectedId);
                    var exists = false;
                    $p.find('option').each(function () {
                        if ($(this).val() === sid) {
                            exists = true;
                            return false;
                        }
                    });
                    if (!exists) {
                        var label = (row && row.vip_product_str) ? row.vip_product_str : ('历史/下架 #' + sid);
                        $p.append($('<option/>').val(sid).text(label));
                    }
                    $p.val(sid);
                }
            }
            window.__mlpAwardVipBind = function (row) {
                row = row || {};
                var level = (row.vip_level === 0 || row.vip_level) ? String(row.vip_level) : '';
                // 固定 VIP 下拉：展示全部上架 VIP 产品（无需选择 vip_level）
                refillVipProducts(level, row.vip_product_id || '', row);

                var ex = decodeExtra(row);
                // coins 模式回显
                if (String(row.prize_type) === 'coins') {
                    var isRandomCoins = (parseInt(row.coins_amount, 10) === -1);
                    $('input[name="coins_mode"][value="' + (isRandomCoins ? 'random' : 'fixed') + '"]').prop('checked', true);
                    if (isRandomCoins) {
                        $('#mlp-coins-random-wrap input[name="coins_random_min"]').val(row.coins_random_min != null ? row.coins_random_min : 0);
                        $('#mlp-coins-random-wrap input[name="coins_random_max"]').val(row.coins_random_max != null ? row.coins_random_max : 0);
                        $('#mlp-coins-fixed-wrap input[name="coins_amount"]').val('');
                    } else {
                        $('#mlp-coins-fixed-wrap input[name="coins_amount"]').val(row.coins_amount != null ? row.coins_amount : '');
                        $('#mlp-coins-random-wrap input[name="coins_random_min"]').val(0);
                        $('#mlp-coins-random-wrap input[name="coins_random_max"]').val(0);
                    }
                }

                // vip 模式回显
                if (String(row.prize_type) === 'vip') {
                    var rp = row.vip_random_product_ids;
                    var parsed = [];
                    if (Array.isArray(rp)) parsed = rp;
                    else if (typeof rp === 'string' && rp) { try { parsed = JSON.parse(rp) || []; } catch (e) { parsed = []; } }
                    var isRandomVip = Array.isArray(parsed);
                    $('input[name="vip_mode"][value="' + (isRandomVip ? 'random' : 'fixed') + '"]').prop('checked', true);
                    refillVipRandomProducts(isRandomVip ? parsed : []);
                } else {
                    refillVipRandomProducts([]);
                }

                form.render();
                syncModeVisibility();
            };
            // 新增弹窗默认初始化一次（避免首次进入模式区块不显示）
            setTimeout(function () {
                if (window.__mlpAwardVipBind) {
                    window.__mlpAwardVipBind({});
                }
            }, 0);
            // prize_type 切换交互
            form.on('select', function () { setTimeout(syncModeVisibility, 0); });
            form.on('radio', function () { setTimeout(syncModeVisibility, 0); });

            // 保存前组装落库字段
            form.on('submit(save)', function (data) {
                var field = data.field || {};
                var prizeType = field.prize_type || '';
                var extra = {};
                if (field.extra) {
                    try { extra = JSON.parse(field.extra); } catch (e) { extra = {}; }
                }

                if (prizeType === 'coins') {
                    var cm = $('input[name="coins_mode"]:checked').val() || 'fixed';
                    field.coins_mode = cm;
                    if (cm === 'random') {
                        // 随机：coins_amount 用 -1，范围直接用数据库字段 coins_random_min/max
                        field.coins_amount = -1;
                        var mn = $('#mlp-coins-random-wrap input[name="coins_random_min"]').val();
                        var mx = $('#mlp-coins-random-wrap input[name="coins_random_max"]').val();
                        field.coins_random_min = mn !== '' ? parseInt(mn, 10) : 0;
                        field.coins_random_max = mx !== '' ? parseInt(mx, 10) : 0;
                    } else {
                        var fixed = $('#mlp-coins-fixed-wrap input[name="coins_amount"]').val();
                        field.coins_amount = fixed !== '' ? parseInt(fixed, 10) : 0;
                        field.coins_random_min = 0;
                        field.coins_random_max = 0;
                    }
                    field.vip_days = 0;
                    field.vip_product_id = '';
                    field.vip_random_product_ids = '';
                    $('input[name="vip_days"]').val('0');
                    $('input[name="vip_random_product_ids"]').val('');
                } else if (prizeType === 'vip') {
                    var vm = $('input[name="vip_mode"]:checked').val() || 'fixed';
                    field.vip_mode = vm;
                    field.coins_amount = 0;
                    field.coins_random_min = 0;
                    field.coins_random_max = 0;
                    field.vip_days = 0;
                    if (vm === 'random') {
                        field.vip_product_id = '';
                        var ids = [];
                        $('#mlp-vip-random-products option:selected').each(function () { ids.push(parseInt($(this).val(), 10)); });
                        field.vip_random_product_ids = JSON.stringify(ids); // 空数组=全部
                    } else {
                        field.vip_random_product_ids = '';
                    }

                    $('input[name="vip_days"]').val('0');
                    $('input[name="vip_random_product_ids"]').val(field.vip_random_product_ids || '');
                } else {
                    field.coins_random_min = 0;
                    field.coins_random_max = 0;
                    field.vip_random_product_ids = '';

                    $('input[name="vip_random_product_ids"]').val('');
                }

                field.extra = JSON.stringify(extra);
                $('textarea[name="extra"]').val(field.extra);
                data.field = field;
                return true;
            });

            form.on('select(mlp_vip_level)', function (data) {
                refillVipProducts(data.value || '', '', {});
                form.render('select');
            });
        });
    })();
    xx.use({
        url: '<?php echo url_backend("listAjax") ?>',
        saveUrl: '<?php echo url_backend("save") ?>',
        uploadUrl: '<?php echo url_backend("upload/upload") ?>',
        title: '抽奖奖项',
        pk: 'id',
        cols: [[
            {field: 'id', title: 'id', width: 70},
            {field: 'activity_name', title: '活动', width: 160},
            {field: 'activity_id', title: 'activity_id', hide: true, width: 1},
            {field: 'name', title: '名称', width: 140},
            {
                field: 'prize_image_full', title: '奖项图', width: 88, templet: function (d) {
                    if (d.prize_image) {
                        return '<img src="' + d.prize_image_full + '" style="width:56px;height:56px;object-fit:cover;cursor:pointer" onclick="show_img(\'' + d.prize_image_full + '\')">';
                    }
                    return '--';
                }
            },
            {
                field: 'prize_icon_full', title: 'icon', width: 64, templet: function (d) {
                    if (d.prize_icon) {
                        return '<img src="' + d.prize_icon_full + '" style="width:40px;height:40px;object-fit:cover;cursor:pointer" onclick="show_img(\'' + d.prize_icon_full + '\')">';
                    }
                    return '--';
                }
            },
            {field: 'prize_type_str', title: '类型', width: 90},
            {field: 'is_win_str', title: '中奖', width: 72},
            {field: 'is_win', title: 'is_win', hide: true, width: 1},
            // 隐藏列：保证行缓存含编辑弹窗依赖的原始字段（保存后 obj.update 合并不会丢键）
            {field: 'prize_desc', title: 'prize_desc', hide: true, width: 1},
            {field: 'prize_image', title: 'prize_image', hide: true, width: 1},
            {field: 'prize_icon', title: 'prize_icon', hide: true, width: 1},
            {field: 'prize_type', title: 'prize_type', hide: true, width: 1},
            {field: 'status', title: 'status', hide: true, width: 1},
            {field: 'status_str', title: '状态', width: 70},
            {field: 'sort_order', title: '排序', width: 70},
            {field: 'win_probability', title: '概率%', width: 72},
            {field: 'total_stock', title: '总份', width: 70},
            {field: 'issued_count', title: '已发', width: 70},
            {field: 'per_user_cap', title: '每人cap', width: 80},
            {
                field: 'coins_amount', title: '金币', width: 90, templet: function (d) {
                    var v = parseInt(d.coins_amount, 10);
                    if (v === -1) {
                        var mn = (d.coins_random_min === 0 || d.coins_random_min) ? d.coins_random_min : '';
                        var mx = (d.coins_random_max === 0 || d.coins_random_max) ? d.coins_random_max : '';
                        if (mn !== '' && mx !== '') {
                            return mn + '/' + mx;
                        }
                        return '--';
                    }
                    return (d.coins_amount === 0 || d.coins_amount) ? d.coins_amount : '--';
                }
            },
            {field: 'coins_random_min', title: 'coins_random_min', hide: true, width: 1},
            {field: 'coins_random_max', title: 'coins_random_max', hide: true, width: 1},
            {field: 'vip_days', title: 'VIP天', width: 70},
            {field: 'vip_product_id', title: 'vip_product_id', hide: true, width: 1},
            {field: 'vip_random_product_ids', title: 'vip_random_product_ids', hide: true, width: 1},
            {field: 'vip_level_label', title: 'VIP类型', width: 90},
            {field: 'vip_grant_type_str', title: '发放类型', width: 80},
            {field: 'vip_product_str', title: 'VIP产品', width: 160},
            {field: 'vip_random_product_ids_str', title: '随机IDs', width: 180},
            {field: 'extra', title: 'extra', hide: true, width: 1},
            {field: 'created_at', title: '创建时间', width: 165},
            {fixed: 'right', width: 100, title: '操作', align: 'center', toolbar: '#operate-toolbar'}
        ]],
        event: {
            toolbar: {
                addUser: function (obj, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    nextFn();
                    setTimeout(function () {
                        if (window.__mlpAwardVipBind) {
                            window.__mlpAwardVipBind({});
                        }
                    }, 150);
                }
            },
            operate: {
                edit: function (obj, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    nextFn();
                    setTimeout(function () {
                        if (window.__mlpAwardVipBind) {
                            window.__mlpAwardVipBind(obj.data || {});
                        }
                    }, 150);
                }
            }
        }
    });

    // 在 layer success 里 form.render 之后同步下拉框选中值（否则 layui 可能重置为第一项）
    Util.on('render', function (form, obj, $) {
        if (!obj || !obj.data) {
            return;
        }
        Util.renderSelect(obj.data, $, form);
    });
</script>
