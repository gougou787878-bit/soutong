        <script>
            layui.laydate.render({
                elem: '#start'
            })
            layui.laydate.render({
                elem: '#end'
            })
            function showUser(aff) {
                var url = "d.php?mod=user&code=index&aff=" + aff
                layerOpen(url, '用户详情')
            }

            function layerOpen(url, title) {
                parent.layer.open({
                    type: 2,
                    title: title,
                    closeBtn: 1,
                    shadeClose: true,
                    shade: [0.5],
                    area: ['1200px', '500px'],
                    content: url
                })
            }

            function getAjax(url) {
                $.ajax({
                    url: url,
                    type: 'GET',
                    success: function (res) {
                        if (res.status == 1) {
                            layer.msg(res.data, {icon: 1})
                        } else {
                            layer.msg(res.data, {icon: 5})
                        }
                    }
                })
            }

            function reload(msg) {
                layer.msg(msg, {icon: 1})
                setTimeout(function () {
                    window.location.reload()
                }, 3000)
            }
        </script>
