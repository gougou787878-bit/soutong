<script>
    
    xx.use({
        url: '<?php echo url_backend("listAjax") ?>',
        saveUrl: '<?php echo url_backend("accept") ?>',
        delUrl: '<?php echo url_backend("del") ?>',
        delALlUrl: undefined,
        uploadUrl: undefined,
        title: '数据表',
        pk: 'id',
        cols: [[
            /*  {type: 'checkbox', fixed: 'left'}*/
            {field: 'id', title: 'id'}
            , {title: '推荐人', width: 275, templet: "#member-basis"}
            , {field: 'comment', title: '评论'}
            , {field: 'find_id', title: '求片编号'}
            , {field: 'mvIds', title: '视频编号'}
            , {field: 'praize', title: '点赞'}
            , {field: 'is_accept_str', title: '采纳状态'}
            /*  , {field: 'status_str', title: '状态'}*/
            , {field: 'created_str', title: ' 创建时间'}
            , {fixed: 'right', width: 240, title: '操作', align: 'center', toolbar: '#operate-toolbar'}
        ]],
          event:{

            operate: {
                accept: function (obj, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    var $this = $(this);
                    var id = $this.data('pk'); // 获取 data-pk
                    console.log("采纳ID：", id);

                    if (!id) {
                        Util.msgErr('ID 不存在，无法采纳');
                        return;
                    }

                    layer.confirm('确定要采纳吗?', function (index2) {
                        ajax.post("<?php echo url_backend('accept')?>", {id: id})
                            .then(function (json) {
                                if (json.code) {
                                    Util.msgErr(json.msg);
                                } else {
                                    Util.msgOk(json.msg, function () {
                                        obj.del();
                                    });
                                }
                                layer.close(index2); // 关闭弹窗
                            })
                            .catch(function () {
                                Util.msgErr('请求失败，请稍后重试');
                                layer.close(index2);
                            });
                    });
                }
            }

        }
    });
</script>
