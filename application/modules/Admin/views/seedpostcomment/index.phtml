            , {field: 'is_top', title: '置顶', type: "switch", value: "1|0", edit: true, width: 120}
            // , {field: 'refuse_reason', title: '拒绝通过原因'}
            , {field: 'created_at', title: '创建时间',width: 150}
            // , {field: 'updated_at', title: 'updated_at'}
            // , {field: 'is_finished', title: '资源是否处理完 0未处理 1已处理'}
            , {fixed: 'right', width: 340, title: '操作', align: 'center', toolbar: '#operate-toolbar'}
        ]],
        event: {
            'toolbar': {
                addUser: function (obj, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    xx.config('event.renderTree', xx.emptyFn()).call(this, obj, table, ajax, laytpl, layerEle, form, $, nextFn)
                },
                passSelect: function (obj, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    var checkStatus = table.checkStatus(obj.config.id), data = checkStatus.data,
                        pkValAry = [],
                        pkName = $(this).data('pk');

                    for (var i = 0; i < data.length; i++) {
                        if (typeof (data[i][pkName]) !== "undefined") {
                            pkValAry.push(data[i][pkName])
                        }
                    }
                    if (pkValAry.length === 0) {
                        return Util.msgErr('请先选择行');
                    }

                    layer.confirm('确定审核通过吗?', function (index) {
                        layer.close(index);
                        ajax.post("<?php echo url_backend("passAll") ?>", {
                            "ids": pkValAry.join(','),
                        })
                            .then(function (json) {
                                if (json.code) {
                                    Util.msgErr(json.msg);
                                } else {
                                    Util.msgOk(json.msg, function (){
                                        Util.reload();
                                    });
                                }
                            })
                    });
                },
                refuseSelect: function (obj, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    var checkStatus = table.checkStatus(obj.config.id), data = checkStatus.data,
                        pkValAry = [],
                        pkName = $(this).data('pk');

                    for (var i = 0; i < data.length; i++) {
                        if (typeof (data[i][pkName]) !== "undefined") {
                            pkValAry.push(data[i][pkName])
                        }
                    }
                    if (pkValAry.length === 0) {
                        return Util.msgErr('请先选择行');
                    }
                    nextFn(undefined, function (layerIndex) {
                        form.val("form-save", {
                            "comment_ids": pkValAry.join(',')
                        });
                        form.render(null, 'form-save');
                        Util.formSubmit("<?php echo url_backend('batchRefuse')?>", form, ajax, 'refuseSelect', function (json) {
                            layer.close(layerIndex);
                            if (json.code == '0') {
                                Util.msgOk(json.msg, function () {
                                    Util.reload();
                                });
                            } else {
                                Util.msgErr(json.msg);
                            }
                        });
                    });
                },
            },
            operate: {
                /**
                 * 通过
                 */
                "pass": function (event, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    var $this = $(this);
                    layer.confirm('真的通过审核吗?', function (index) {
                        layer.close(index);
                        ajax.post("<?php echo url_backend("doPass") ?>", {"id": $this.data('pk')})
                            .then(function (json) {
                                if (json.code) {
                                    Util.msgErr(json.msg);
                                } else {
                                    Util.msgOk(json.msg, Util.reload);
                                }
                            })
                    });
                },
                /**
                 * 拉黑
                 */
                "blackdo": function (event, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    var $this = $(this);
                    layer.confirm('确定当前操作?', function (index) {
                        layer.close(index);
                        ajax.post("<?php echo url_backend("doBlack") ?>", {
                            "id": $this.data('pk'),
                            'flag': $this.data('flag')
                        })
                            .then(function (json) {
                                if (json.code) {
                                    Util.msgErr(json.msg);
                                } else {
                                    Util.msgOk(json.msg, Util.reload);
                                }
                            })
                    });
                },
                /**
                 * 拒绝
                 */
                "refuse": function (event, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    var $this = $(this);
                    var index3 = layer.load(0, {time: 3 * 1000, shade: [0.5, '#666']});
                    ajax.post("<?php echo url_backend("doReject") ?>", {"id": $this.data('pk')})
                        .then(function (json) {
                            layer.close(index);
                            layer.close(index);
                            layer.close(index3);
                            if (json.code) {
                                Util.msgErr(json.msg);
                            } else {
                                Util.msgOk(json.msg, Util.reload);
                            }
                        })

                }
            }
        },
    })
    ;
</script>
<?php echo \Layui::renderJs() ?><?php importView("fooler.phtml"); ?>