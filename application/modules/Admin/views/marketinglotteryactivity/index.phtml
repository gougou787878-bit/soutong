<script>
    var MARKETING_LOTTERY_PRODUCTS = <?php echo json_encode($vipProducts ?? [], JSON_UNESCAPED_UNICODE); ?>;

    function mlEscapeHtml(value) {
        return String(value === undefined || value === null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function mlParseJsonConfig(raw) {
        if (typeof raw === 'object' && raw !== null) {
            return raw;
        }
        raw = String(raw || '').replace(/&quot;/g, '"').trim();
        if (!raw) {
            return {};
        }
        try {
            return JSON.parse(raw);
        } catch (e) {
            return {};
        }
    }

    function mlProductText(item) {
        var price = Number(item.promo_price || item.price || 0);
        var status = Number(item.status) === 1 ? '' : '（下架）';
        return '#' + item.id + ' ' + item.name + ' ¥' + price + status;
    }

    function mlProductOptions(selectedId) {
        var html = '<option value="">请选择商品</option>';
        selectedId = String(selectedId || '');
        for (var i = 0; i < MARKETING_LOTTERY_PRODUCTS.length; i++) {
            var item = MARKETING_LOTTERY_PRODUCTS[i];
            var id = String(item.id);
            html += '<option value="' + mlEscapeHtml(id) + '"' + (id === selectedId ? ' selected' : '') + '>' + mlEscapeHtml(mlProductText(item)) + '</option>';
        }
        if (selectedId && html.indexOf('value="' + mlEscapeHtml(selectedId) + '"') === -1) {
            html += '<option value="' + mlEscapeHtml(selectedId) + '" selected>#' + mlEscapeHtml(selectedId) + '（历史商品）</option>';
        }
        return html;
    }

    function mlAddProductRow($, $box, productId, plays) {
        var html = '<div class="ml-product-row">'
            + '<select class="layui-input ml-product-id" lay-ignore>' + mlProductOptions(productId) + '</select>'
            + '<input type="number" min="0" max="200" class="layui-input ml-product-plays" placeholder="赠送次数" value="' + mlEscapeHtml(plays || '') + '">'
            + '<button type="button" class="layui-btn layui-btn-primary layui-btn-sm ml-remove-product">删除</button>'
            + '</div>';
        $box.append(html);
    }

    function mlSelectedGrantRules($root) {
        var rules = [];
        var allowed = {product_tier: true, multiple: true, once: true, condition_group: true};
        $root.find('.ml-rule-check.active').each(function () {
            var val = layui.$(this).data('rule');
            if (allowed[val] && rules.indexOf(val) === -1) {
                rules.push(val);
            }
        });
        return rules.length ? rules : ['product_tier'];
    }

    function mlHasGrantRule(rules, rule) {
        return rules.indexOf(rule) !== -1;
    }

    function mlCollectConfig($root) {
        var rules = mlSelectedGrantRules($root);
        var cfg = {grant_modes: rules, rules: {}};
        if (mlHasGrantRule(rules, 'product_tier')) {
            var productRule = {products: {}};
            $root.find('.ml-product-row').each(function () {
                var $row = layui.$(this);
                var productId = String($row.find('.ml-product-id').val() || '').trim();
                var plays = parseInt($row.find('.ml-product-plays').val(), 10);
                if (productId && plays > 0) {
                    productRule.products[productId] = Math.min(200, plays);
                }
            });
            cfg.rules.product_tier = productRule;
        }
        if (mlHasGrantRule(rules, 'once') || mlHasGrantRule(rules, 'multiple')) {
            var minAmount = parseFloat($root.find('.ml-min-amount').val()) || 0;
            if (mlHasGrantRule(rules, 'once')) {
                cfg.rules.once = {min_amount: minAmount};
            }
            if (mlHasGrantRule(rules, 'multiple')) {
                cfg.rules.multiple = {
                    min_amount: minAmount,
                    step_amount: parseFloat($root.find('.ml-step-amount').val()) || 0
                };
            }
        }
        if (mlHasGrantRule(rules, 'condition_group')) {
            var conditionCfg = {
                condition_logic: 'or',
                invitee_plays: Math.max(0, Math.min(200, parseInt($root.find('.ml-invitee-plays').val(), 10) || 0)),
                inviter_plays: Math.max(0, Math.min(200, parseInt($root.find('.ml-inviter-plays').val(), 10) || 0)),
                conditions: []
            };
            var signDays = parseInt($root.find('.ml-condition-sign-days').val(), 10) || 0;
            var rechargeAmount = parseFloat($root.find('.ml-condition-recharge-amount').val()) || 0;
            if (signDays > 0) {
                conditionCfg.conditions.push({type: 'continuous_sign', days: signDays});
            }
            if (rechargeAmount > 0) {
                conditionCfg.conditions.push({type: 'recharge_total', amount: rechargeAmount, scope: 'activity'});
            }
            cfg.rules.condition_group = conditionCfg;
        }
        var json = JSON.stringify(cfg);
        $root.find('.ml-config-json').val(json);
        $root.find('.ml-config-preview').val(JSON.stringify(cfg, null, 2));
        return json;
    }

    function mlRefreshConfigUi($root) {
        var rules = mlSelectedGrantRules($root);
        $root.find('.ml-product-config').toggle(mlHasGrantRule(rules, 'product_tier'));
        $root.find('.ml-amount-config').toggle(mlHasGrantRule(rules, 'once') || mlHasGrantRule(rules, 'multiple'));
        $root.find('.ml-condition-config').toggle(mlHasGrantRule(rules, 'condition_group'));
        $root.find('.ml-step-row').toggle(mlHasGrantRule(rules, 'multiple'));
        mlCollectConfig($root);
    }

    function mlHydrateConfig($, $root, rawConfig) {
        var cfg = mlParseJsonConfig(rawConfig);
        var rules = cfg.grant_modes || [];
        var ruleCfgs = cfg.rules || {};
        if (!Array.isArray(rules) || !rules.length) {
            var legacyRule = cfg.amount_stat_type || 'product_tier';
            if (legacyRule === 'product' || legacyRule === 'products') {
                legacyRule = 'product_tier';
            }
            rules = [legacyRule];
            ruleCfgs = {};
            ruleCfgs[legacyRule] = cfg;
        }
        var allowedRules = {product_tier: true, multiple: true, once: true, condition_group: true};
        rules = rules.filter(function (item, idx) {
            return allowedRules[item] && rules.indexOf(item) === idx;
        });
        if (!rules.length) {
            rules = ['product_tier'];
        }
        $root.find('.ml-rule-check').removeClass('active');
        for (var rj = 0; rj < rules.length; rj++) {
            $root.find('.ml-rule-check[data-rule="' + rules[rj] + '"]').addClass('active');
        }
        var amountCfg = ruleCfgs.multiple || ruleCfgs.once || {};
        $root.find('.ml-min-amount').val(amountCfg.min_amount || '');
        $root.find('.ml-step-amount').val((ruleCfgs.multiple && ruleCfgs.multiple.step_amount) || '');
        var conditionCfg = ruleCfgs.condition_group || {};
        $root.find('.ml-invitee-plays').val(conditionCfg.invitee_plays || 1);
        $root.find('.ml-inviter-plays').val(conditionCfg.inviter_plays || 1);

        var $box = $root.find('.ml-product-rows').empty();
        var products = (ruleCfgs.product_tier && ruleCfgs.product_tier.products) || {};
        var hasProduct = false;
        for (var productId in products) {
            if (Object.prototype.hasOwnProperty.call(products, productId)) {
                hasProduct = true;
                mlAddProductRow($, $box, productId, products[productId]);
            }
        }
        if (!hasProduct) {
            mlAddProductRow($, $box, '', '');
        }
        var conditions = conditionCfg.conditions || [];
        $root.find('.ml-condition-sign-days').val('');
        $root.find('.ml-condition-recharge-amount').val('');
        for (var i = 0; i < conditions.length; i++) {
            if (conditions[i].type === 'continuous_sign') {
                $root.find('.ml-condition-sign-days').val(conditions[i].days || '');
            } else if (conditions[i].type === 'recharge_total') {
                $root.find('.ml-condition-recharge-amount').val(conditions[i].amount || '');
            }
        }
        mlRefreshConfigUi($root);
    }

    function mlBindConfigEvents($, $root) {
        $root.off('change.mlConfig input.mlConfig click.mlConfig');
        $root.on('click.mlConfig', '.ml-rule-check', function () {
            var $item = layui.$(this);
            $item.toggleClass('active');
            if ($root.find('.ml-rule-check.active').length === 0) {
                $item.addClass('active');
            }
            mlRefreshConfigUi($root);
        });
        $root.on('change.mlConfig input.mlConfig', '.ml-min-amount,.ml-step-amount,.ml-product-id,.ml-product-plays,.ml-invitee-plays,.ml-inviter-plays,.ml-condition-sign-days,.ml-condition-recharge-amount', function () {
            mlCollectConfig($root);
        });
        $root.on('click.mlConfig', '.ml-add-product', function () {
            mlAddProductRow($, $root.find('.ml-product-rows'), '', '');
            mlCollectConfig($root);
        });
        $root.on('click.mlConfig', '.ml-remove-product', function () {
            layui.$(this).closest('.ml-product-row').remove();
            if ($root.find('.ml-product-row').length === 0) {
                mlAddProductRow($, $root.find('.ml-product-rows'), '', '');
            }
            mlCollectConfig($root);
        });
    }

    function mlValidateConfig($root) {
        var rules = mlSelectedGrantRules($root);
        if (mlHasGrantRule(rules, 'product_tier')) {
            var hasProduct = false;
            $root.find('.ml-product-row').each(function () {
                var $row = layui.$(this);
                var productId = String($row.find('.ml-product-id').val() || '').trim();
                var plays = parseInt($row.find('.ml-product-plays').val(), 10) || 0;
                if (productId && plays > 0) {
                    hasProduct = true;
                }
            });
            if (!hasProduct) {
                return '已勾选“按商品套餐赠送”，请至少选择一个商品并填写赠送次数';
            }
        }
        if (mlHasGrantRule(rules, 'once') || mlHasGrantRule(rules, 'multiple')) {
            var minAmount = parseFloat($root.find('.ml-min-amount').val()) || 0;
            if (minAmount <= 0) {
                return '已勾选金额赠送规则，请填写最低金额';
            }
        }
        if (mlHasGrantRule(rules, 'multiple')) {
            var stepAmount = parseFloat($root.find('.ml-step-amount').val()) || 0;
            if (stepAmount <= 0) {
                return '已勾选“按支付金额倍数赠送”，请填写每满金额';
            }
        }
        if (mlHasGrantRule(rules, 'condition_group')) {
            var signDays = parseInt($root.find('.ml-condition-sign-days').val(), 10) || 0;
            var rechargeAmount = parseFloat($root.find('.ml-condition-recharge-amount').val()) || 0;
            var inviteePlays = parseInt($root.find('.ml-invitee-plays').val(), 10) || 0;
            var inviterPlays = parseInt($root.find('.ml-inviter-plays').val(), 10) || 0;
            if (signDays <= 0 && rechargeAmount <= 0) {
                return '已勾选“条件达成赠送”，请填写连续签到天数或累计充值金额';
            }
            if (inviteePlays <= 0 && inviterPlays <= 0) {
                return '已勾选“条件达成赠送”，请填写邀请人或被邀请人赠送次数';
            }
        }
        return '';
    }

    layui.use(['form'], function () {
        layui.form.on('submit(save)', function (data) {
            var $form = layui.$(data.form);
            var err = mlValidateConfig($form);
            if (err) {
                layui.layer.msg(err, {icon: 2});
                return false;
            }
            mlCollectConfig($form);
        });
    });

    function renderDateTimePicker($) {
        $('.x-date-time').each(function () {
            layui.laydate.render({elem: this, type: 'datetime'});
        });
    }

    function normalizeMarketingLotteryRow(d) {
        d = d || {};
        if (!('status' in d) && d.status_str) {
            if (d.status_str === '上架') {
                d.status = 1;
            } else if (d.status_str === '下架') {
                d.status = 0;
            }
        }
        if (!('trigger_scenario' in d) && d.trigger_str !== undefined && d.trigger_str !== null) {
            var tsMap = {'支付成功后': 'pay_success', '无': ''};
            if (Object.prototype.hasOwnProperty.call(tsMap, d.trigger_str)) {
                d.trigger_scenario = tsMap[d.trigger_str];
            }
        }
        return d;
    }
    xx.use({
        url: '<?php echo url_backend("listAjax") ?>',
        saveUrl: '<?php echo url_backend("save") ?>',
        uploadUrl: '<?php echo url_backend("upload/upload") ?>',
        title: '抽奖活动',
        pk: 'id',
        cols: [[
            {field: 'id', title: 'id', width: 80},
            {field: 'name', title: '名称', width: 160},
            {
                field: 'activity_image_full', title: '活动图', width: 88, templet: function (d) {
                    if (d.activity_image) {
                        return '<img src="' + d.activity_image_full + '" style="width:56px;height:56px;object-fit:cover;cursor:pointer" onclick="show_img(\'' + d.activity_image_full + '\')">';
                    }
                    return '--';
                }
            },
            {
                field: 'icon_full', title: 'icon', width: 64, templet: function (d) {
                    if (d.icon) {
                        return '<img src="' + d.icon_full + '" style="width:40px;height:40px;object-fit:cover;cursor:pointer" onclick="show_img(\'' + d.icon_full + '\')">';
                    }
                    return '--';
                }
            },
            {field: 'type_str', title: '类型', width: 90},
            {field: 'trigger_str', title: '触发情景', width: 110},
            {field: 'status_str', title: '状态', width: 70},
            // 隐藏列：保证行缓存含原始值，编辑弹窗 laytpl 能读到 status / trigger_scenario（与 listAjax 返回字段一致）
            {field: 'status', title: 'status', hide: true, width: 1},
            {field: 'trigger_scenario', title: 'trigger_scenario', hide: true, width: 1},
            {field: 'show_start_at', title: '预热开始', width: 160},
            {field: 'start_at', title: '开始', width: 160},
            {field: 'end_at', title: '结束', width: 160},
            {field: 'daily_limit', title: '每人/日', width: 80},
            {field: 'daily_send_limit', title: '活动/日', width: 80},
            {field: 'per_user_limit', title: '每人/期', width: 80},
            {field: 'total_limit', title: '总限', width: 70},
            {field: 'receive_valid_days', title: '有效天数', width: 90},
            {field: 'creator_name', title: '创建人', width: 110},
            {field: 'creator_uid', title: 'creator_uid', hide: true, width: 1},
            {field: 'created_at', title: '创建时间', width: 165},
            {field: 'updated_at', title: '更新时间', width: 165},
            {fixed: 'right', width: 100, title: '操作', align: 'center', toolbar: '#operate-toolbar'}
        ]],
        event: {
            toolbar: {
                addUser: function (obj, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    obj.data = normalizeMarketingLotteryRow(obj.data);
                    nextFn();
                    renderDateTimePicker($);
                }
            },
            operate: {
                edit: function (obj, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    obj.data = normalizeMarketingLotteryRow(obj.data);
                    nextFn();
                    renderDateTimePicker($);
                }
            }
        }
    });
    // 必须在 layer success 里 form.render 之后再同步下拉，否则会再次被 layui 重置成第一项（下架/无）
    Util.on('render', function (form, obj, $) {
        if (!obj || !obj.data) {
            return;
        }
        Util.renderSelect(obj.data, $, form);
        var $root = $('.form-dialog');
        mlHydrateConfig($, $root, obj.data.config);
        mlBindConfigEvents($, $root);
    });
</script>
