<script>
    var MARKETING_LOTTERY_PRODUCTS = <?php echo json_encode($vipProducts ?? [], JSON_UNESCAPED_UNICODE); ?>;

    function mlEscapeHtml(value) {
        return String(value === undefined || value === null ? '' : value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function mlParseJsonConfig(raw) {
        if (typeof raw === 'object' && raw !== null) {
            return raw;
        }
        raw = String(raw || '').replace(/&quot;/g, '"').trim();
        if (!raw) {
            return {};
        }
        try {
            return JSON.parse(raw);
        } catch (e) {
            return {};
        }
    }

    function mlProductText(item) {
        var price = Number(item.promo_price || item.price || 0);
        var status = Number(item.status) === 1 ? '' : '（下架）';
        return '#' + item.id + ' ' + item.name + ' ¥' + price + status;
    }

    function mlProductOptions(selectedId) {
        var html = '<option value="">请选择商品</option>';
        selectedId = String(selectedId || '');
        for (var i = 0; i < MARKETING_LOTTERY_PRODUCTS.length; i++) {
            var item = MARKETING_LOTTERY_PRODUCTS[i];
            var id = String(item.id);
            html += '<option value="' + mlEscapeHtml(id) + '"' + (id === selectedId ? ' selected' : '') + '>' + mlEscapeHtml(mlProductText(item)) + '</option>';
        }
        if (selectedId && html.indexOf('value="' + mlEscapeHtml(selectedId) + '"') === -1) {
            html += '<option value="' + mlEscapeHtml(selectedId) + '" selected>#' + mlEscapeHtml(selectedId) + '（历史商品）</option>';
        }
        return html;
    }

    function mlAddProductRow($, $box, productId, plays) {
        var html = '<div class="ml-product-row">'
            + '<select class="layui-input ml-product-id" lay-ignore>' + mlProductOptions(productId) + '</select>'
            + '<input type="number" min="0" max="200" class="layui-input ml-product-plays" placeholder="赠送次数" value="' + mlEscapeHtml(plays || '') + '">'
            + '<button type="button" class="layui-btn layui-btn-primary layui-btn-sm ml-remove-product">删除</button>'
            + '</div>';
        $box.append(html);
    }

    function mlCollectConfig($root) {
        var rule = $root.find('.ml-grant-rule').val() || 'product_tier';
        var cfg = {amount_stat_type: rule};
        if (rule === 'product_tier') {
            cfg.products = {};
            $root.find('.ml-product-row').each(function () {
                var $row = layui.$(this);
                var productId = String($row.find('.ml-product-id').val() || '').trim();
                var plays = parseInt($row.find('.ml-product-plays').val(), 10);
                if (productId && plays > 0) {
                    cfg.products[productId] = Math.min(200, plays);
                }
            });
        } else {
            cfg.min_amount = parseFloat($root.find('.ml-min-amount').val()) || 0;
            if (rule === 'multiple') {
                cfg.step_amount = parseFloat($root.find('.ml-step-amount').val()) || 0;
            }
        }
        var json = JSON.stringify(cfg);
        $root.find('.ml-config-json').val(json);
        $root.find('.ml-config-preview').val(JSON.stringify(cfg, null, 2));
        return json;
    }

    function mlRefreshConfigUi($root) {
        var rule = $root.find('.ml-grant-rule').val() || 'product_tier';
        $root.find('.ml-product-config').toggle(rule === 'product_tier');
        $root.find('.ml-amount-config').toggle(rule !== 'product_tier');
        $root.find('.ml-step-row').toggle(rule === 'multiple');
        mlCollectConfig($root);
    }

    function mlHydrateConfig($, $root, rawConfig) {
        var cfg = mlParseJsonConfig(rawConfig);
        var rule = cfg.amount_stat_type || 'product_tier';
        if (rule === 'product' || rule === 'products') {
            rule = 'product_tier';
        }
        if (rule !== 'product_tier' && rule !== 'multiple' && rule !== 'once') {
            rule = 'once';
        }
        $root.find('.ml-grant-rule').val(rule);
        $root.find('.ml-min-amount').val(cfg.min_amount || '');
        $root.find('.ml-step-amount').val(cfg.step_amount || '');

        var $box = $root.find('.ml-product-rows').empty();
        var products = cfg.products || {};
        var hasProduct = false;
        for (var productId in products) {
            if (Object.prototype.hasOwnProperty.call(products, productId)) {
                hasProduct = true;
                mlAddProductRow($, $box, productId, products[productId]);
            }
        }
        if (!hasProduct) {
            mlAddProductRow($, $box, '', '');
        }
        mlRefreshConfigUi($root);
    }

    function mlBindConfigEvents($, $root) {
        $root.off('change.mlConfig input.mlConfig click.mlConfig');
        $root.on('change.mlConfig', '.ml-grant-rule', function () {
            mlRefreshConfigUi($root);
        });
        $root.on('change.mlConfig input.mlConfig', '.ml-min-amount,.ml-step-amount,.ml-product-id,.ml-product-plays', function () {
            mlCollectConfig($root);
        });
        $root.on('click.mlConfig', '.ml-add-product', function () {
            mlAddProductRow($, $root.find('.ml-product-rows'), '', '');
            mlCollectConfig($root);
        });
        $root.on('click.mlConfig', '.ml-remove-product', function () {
            layui.$(this).closest('.ml-product-row').remove();
            if ($root.find('.ml-product-row').length === 0) {
                mlAddProductRow($, $root.find('.ml-product-rows'), '', '');
            }
            mlCollectConfig($root);
        });
    }

    layui.use(['form'], function () {
        layui.form.on('submit(save)', function (data) {
            mlCollectConfig(layui.$(data.form));
        });
    });

    function renderDateTimePicker($) {
        $('.x-date-time').each(function () {
            layui.laydate.render({elem: this, type: 'datetime'});
        });
    }

    function normalizeMarketingLotteryRow(d) {
        d = d || {};
        if (!('status' in d) && d.status_str) {
            if (d.status_str === '上架') {
                d.status = 1;
            } else if (d.status_str === '下架') {
                d.status = 0;
            }
        }
        if (!('trigger_scenario' in d) && d.trigger_str !== undefined && d.trigger_str !== null) {
            var tsMap = {'支付成功后': 'pay_success', '无': ''};
            if (Object.prototype.hasOwnProperty.call(tsMap, d.trigger_str)) {
                d.trigger_scenario = tsMap[d.trigger_str];
            }
        }
        return d;
    }
    xx.use({
        url: '<?php echo url_backend("listAjax") ?>',
        saveUrl: '<?php echo url_backend("save") ?>',
        uploadUrl: '<?php echo url_backend("upload/upload") ?>',
        title: '抽奖活动',
        pk: 'id',
        cols: [[
            {field: 'id', title: 'id', width: 80},
            {field: 'name', title: '名称', width: 160},
            {
                field: 'activity_image_full', title: '活动图', width: 88, templet: function (d) {
                    if (d.activity_image) {
                        return '<img src="' + d.activity_image_full + '" style="width:56px;height:56px;object-fit:cover;cursor:pointer" onclick="show_img(\'' + d.activity_image_full + '\')">';
                    }
                    return '--';
                }
            },
            {
                field: 'icon_full', title: 'icon', width: 64, templet: function (d) {
                    if (d.icon) {
                        return '<img src="' + d.icon_full + '" style="width:40px;height:40px;object-fit:cover;cursor:pointer" onclick="show_img(\'' + d.icon_full + '\')">';
                    }
                    return '--';
                }
            },
            {field: 'type_str', title: '类型', width: 90},
            {field: 'trigger_str', title: '触发情景', width: 110},
            {field: 'status_str', title: '状态', width: 70},
            // 隐藏列：保证行缓存含原始值，编辑弹窗 laytpl 能读到 status / trigger_scenario（与 listAjax 返回字段一致）
            {field: 'status', title: 'status', hide: true, width: 1},
            {field: 'trigger_scenario', title: 'trigger_scenario', hide: true, width: 1},
            {field: 'show_start_at', title: '预热开始', width: 160},
            {field: 'start_at', title: '开始', width: 160},
            {field: 'end_at', title: '结束', width: 160},
            {field: 'daily_limit', title: '每人/日', width: 80},
            {field: 'daily_send_limit', title: '活动/日', width: 80},
            {field: 'per_user_limit', title: '每人/期', width: 80},
            {field: 'total_limit', title: '总限', width: 70},
            {field: 'receive_valid_days', title: '有效天数', width: 90},
            {field: 'creator_name', title: '创建人', width: 110},
            {field: 'creator_uid', title: 'creator_uid', hide: true, width: 1},
            {field: 'created_at', title: '创建时间', width: 165},
            {field: 'updated_at', title: '更新时间', width: 165},
            {fixed: 'right', width: 100, title: '操作', align: 'center', toolbar: '#operate-toolbar'}
        ]],
        event: {
            toolbar: {
                addUser: function (obj, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    obj.data = normalizeMarketingLotteryRow(obj.data);
                    nextFn();
                    renderDateTimePicker($);
                }
            },
            operate: {
                edit: function (obj, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    obj.data = normalizeMarketingLotteryRow(obj.data);
                    nextFn();
                    renderDateTimePicker($);
                }
            }
        }
    });
    // 必须在 layer success 里 form.render 之后再同步下拉，否则会再次被 layui 重置成第一项（下架/无）
    Util.on('render', function (form, obj, $) {
        if (!obj || !obj.data) {
            return;
        }
        Util.renderSelect(obj.data, $, form);
        var $root = $('.form-dialog');
        mlHydrateConfig($, $root, obj.data.config);
        mlBindConfigEvents($, $root);
    });
</script>
