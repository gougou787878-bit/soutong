<script>
    xx.use({
        url: '<?php echo url_backend("listAjax") ?>',
        saveUrl: '<?php echo url_backend("save") ?>',
        delUrl: '<?php echo url_backend("del") ?>',
        delALlUrl: '<?php echo url_backend("delAll") ?>',
        uploadUrl: undefined,
        title: '数据表',
        pk: 'id',
        cols: [[
            {type: 'checkbox', fixed: 'left', width: 60}
            , {field: 'id', title: 'id', width: 60}
            , {field: 'window_id', title: '窗口id'}
            //, {field: 'from_avater', title: 'from_avater'}
            , {
                field: 'from_avater_full', width: 80, title: '图片', align: 'center', templet: function (d) {
                    if(d.from_avater_full){
                        return '<div onclick="show_img(\''+d.from_avater_full+'\')" ><img width="50" src="' + d.from_avater_full + '" /></div>';
                    }
                    return '';
                }
            }
            , {field: 'from_uuid',width: 250, title: 'from_uuid'}
            , {field: 'from_nickname', title: 'from_nickname'}
            , {field: 'content',width: 240, title: 'content',templet:function (d) {
                    return "<span style='color: #00C1B3'>"+d.content+"</span>"
                }}
            //, {field: 'to_avater', title: 'to_avater'}
            , {
                field: 'to_avater_full', width: 80, title: '图片', align: 'center', templet: function (d) {
                    if(d.to_avater_full){
                        return '<div onclick="show_img(\''+d.to_avater_full+'\')" ><img width="50" src="' + d.to_avater_full + '" /></div>';
                    }
                    return '';
                }
            }
            , {field: 'to_uuid',width: 250, title: 'to_uuid'}
            , {field: 'to_nickname', title: 'to_nickname'}

           // , {field: 'images', title: 'images'}
           // , {field: 'ext', title: '扩展字段'}
            , {field: 'created_at', title: '记录时间'}
            , {fixed: 'right', width: 120, title: '操作', align: 'center', toolbar: '#operate-toolbar'}
        ]],
        'event':{
            'operate':{

                "ban": function (event, table, ajax, laytpl, layerEle, form, $, nextFn) {
                    let in2 = layer.load(0, {time: 6 * 1000, shade: [0.5, '#000']});
                    let $this = $(this),
                        data = {"uuid": $this.data('pk')};
                    layer.confirm('真的禁言码?', function (index) {
                        layer.close(index);

                        ajax.post('<?php echo url_backend('ban')?>', data)
                            .then(function (json) {
                                layer.close(in2);
                                Util.msgOk('操作成功');
                            })
                    });
                }
            }
        }
    });
</script>
